# OpenText Content Server connection
OTCS_BASE_URL=https://your-otcs.example.com/cs/cs
OTCS_USERNAME=your_username
OTCS_PASSWORD=your_password
OTCS_ROOT_NODE=2000

# Ollama (run locally: https://ollama.ai)
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3

# Storage paths
CHROMA_PATH=./chroma_store
PARQUET_PATH=./cold_store.parquet
